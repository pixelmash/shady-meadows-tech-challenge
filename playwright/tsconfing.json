{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "types": ["node", "@playwright/test"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.spec.ts",
    "testData.ts",
    "playwright.config.ts"
  ]
}